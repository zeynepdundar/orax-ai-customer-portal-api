{{!-- Materials page — mirrors src/app/(app)/materials/page.tsx --}}
<div class="p-8 space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-2xl font-semibold text-gray-900">{{pageTitle}}</h2>
      <p class="text-sm text-gray-500 mt-1">{{pageDescription}}</p>
    </div>
    <div class="flex items-center gap-2">
      {{> ui/button label=labels.newMaterial iconBefore="plus"}}
    </div>
  </div>

  {{#> ui/card padding="p-5"}}
    <form method="GET" action="/materials" class="space-y-4">
      <div class="flex items-end gap-4 flex-wrap">
        <div class="w-full max-w-md">
          <label class="block text-xs font-medium text-gray-600 mb-2">{{labels.filterSearch}}</label>
          <input name="search" type="search" value="{{search}}" placeholder="{{labels.filterSearchPlaceholder}}" class="w-full h-9 px-3 py-1 text-sm rounded-lg border bg-gray-50 border-gray-200 outline-none focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 transition" />
        </div>

        <div class="w-64">
          {{> ui/select-box name="tracking" label=labels.filterStatus options=trackingOptions value=tracking extraClass="bg-gray-50 border-gray-200"}}
        </div>

        <button type="submit" class="inline-flex items-center h-8 px-3 text-sm rounded-lg bg-white border border-gray-200 text-gray-900 hover:bg-gray-50">{{labels.filter}}</button>
      </div>

      <div class="mt-4 pt-4 border-t border-gray-200">
        <span class="text-sm text-gray-500">{{resultsCount}} {{labels.resultsFound}}</span>
      </div>
    </form>
  {{/ui/card}}

  {{> ui/data-table columns=columns rowsHtml=rowsHtml}}
</div>
