{{!-- Inventory page — mirrors src/app/(app)/inventory/page.tsx --}}
<div class="p-8 space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-2xl font-semibold text-gray-900">{{pageTitle}}</h2>
      <p class="text-sm text-gray-500 mt-1">{{pageDescription}}</p>
    </div>
    <div class="flex items-center gap-2">
      {{> ui/button label=exportLabel variant="outline" iconBefore="download"}}
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
    {{#each kpiCards}}
      {{> ui/metric-card title=this.title value=this.value icon=this.icon variant=this.variant showAction=true actionContext="inventory"}}
    {{/each}}
  </div>

  {{!-- Filters --}}
  {{#> ui/card padding="p-5"}}
    <form method="GET" action="/inventory" class="space-y-5">
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-2">{{searchLabel}}</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">{{{icon "search" class="w-4 h-4"}}}</span>
          <input name="search" type="search" value="{{search}}" placeholder="{{labels.searchPlaceholder}}" class="w-full h-9 pl-10 pr-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 items-end">
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-2">{{labels.filterPalletNo}}</label>
          <input name="pallet" placeholder="{{labels.enterPalletNo}}" class="w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-2">{{labels.filterSku}}</label>
          <input name="sku" placeholder="{{labels.enterSku}}" class="w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-2">{{labels.filterLot}}</label>
          <input name="lot" placeholder="{{labels.enterLot}}" class="w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200" />
        </div>
        <div>
          {{> ui/select-box name="status" label=labels.filterStatus options=statusOptions value=statusFilter extraClass="h-10 rounded-lg"}}
        </div>
        <div class="flex items-end">
          <button type="submit" class="w-full h-10 inline-flex items-center justify-center rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium">{{filterLabel}}</button>
        </div>
      </div>
    </form>
  {{/ui/card}}

  {{> ui/data-table columns=columns rowsHtml=rowsHtml}}
</div>
