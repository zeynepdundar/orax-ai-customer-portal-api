{{!--
  /customers/new — three-mode "create customer" form.
  Ported from the React CreateCustomer component. All client-side state and
  interactivity (mode tabs, GLN validation, search/select, drag-and-drop
  uploader, duplicate-warning modal, lightweight toasts) lives in the single
  Alpine.js component defined in the <script> at the bottom.

  Form submission goes to POST /customers/new — currently a stub that just
  flashes a success message and bounces back to /customers.
--}}
<div class="p-8" x-data="createCustomer({
  mockResults: {{{json mockSearchResults}}},
  existing: {{{json mockExistingCustomers}}},
  labels: {{{json labels}}}
})">
  <div class="max-w-4xl mx-auto space-y-6">

    {{!-- Header --}}
    <div class="flex items-center gap-4">
      <a href="/customers" class="p-2 rounded-lg hover:bg-gray-100 transition-colors text-gray-600" aria-label="{{labels.back}}">
        {{{icon "arrow-left" class="w-5 h-5"}}}
      </a>
      <div>
        <h1 class="text-2xl font-semibold text-gray-900">{{pageTitle}}</h1>
        <p class="text-sm text-gray-500 mt-1">{{pageSubtitle}}</p>
      </div>
    </div>

    {{!-- Mode Tabs --}}
    <div class="p-1 bg-gray-50 border border-gray-200 rounded-xl">
      <div class="flex gap-1">
        <button type="button" @click="setMode('fetch')"
          :class="mode === 'fetch' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-600 hover:text-gray-900'"
          class="flex-1 px-4 py-3 rounded-lg transition-all text-sm font-medium">
          {{labels.fetchMode}}
        </button>
        <button type="button" @click="setMode('upload')"
          :class="mode === 'upload' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-600 hover:text-gray-900'"
          class="flex-1 px-4 py-3 rounded-lg transition-all text-sm font-medium">
          {{labels.uploadMode}}
        </button>
        <button type="button" @click="setMode('manual')"
          :class="mode === 'manual' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-600 hover:text-gray-900'"
          class="flex-1 px-4 py-3 rounded-lg transition-all text-sm font-medium">
          {{labels.manualMode}}
        </button>
      </div>
    </div>

    {{!-- MODE 1: Fetch from OraxAI --}}
    <div x-show="mode === 'fetch'" x-cloak class="p-6 bg-white shadow-sm border border-gray-100 rounded-xl space-y-5">
      <div>
        <p class="text-sm font-semibold text-gray-700 mb-3">{{labels.fetchDescription}}</p>
        <div class="flex gap-3">
          <div class="flex-1 relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">{{{icon "search" class="w-4 h-4"}}}</span>
            <input x-model="searchQuery" @keydown.enter.prevent="runSearch()"
              type="text" placeholder="{{labels.searchPlaceholder}}"
              class="w-full h-9 pl-10 pr-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
          </div>
          <button type="button" @click="runSearch()" :disabled="isSearching || !searchQuery"
            class="inline-flex items-center justify-center h-9 px-4 text-sm rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium disabled:opacity-50 disabled:pointer-events-none">
            <span x-text="isSearching ? '{{labels.fetching}}' : '{{labels.fetchButton}}'"></span>
          </button>
        </div>
      </div>

      {{!-- Search results --}}
      <div x-show="searchResults.length > 0" x-cloak>
        <p class="text-sm font-semibold text-gray-700 mb-3">{{labels.selectCustomer}}</p>
        <div class="space-y-2">
          <template x-for="c in searchResults" :key="c.id">
            <button type="button" @click="selectSearchResult(c)"
              :class="selectedCustomerId === c.id ? 'border-blue-600 bg-blue-50' : 'border-gray-200 hover:border-gray-300 bg-white'"
              class="w-full p-4 rounded-lg border-2 transition-all text-left">
              <div class="flex justify-between items-start">
                <div>
                  <p class="font-medium text-gray-900" x-text="c.name"></p>
                  <p class="text-sm text-gray-600 font-mono mt-1">GLN: <span x-text="c.gln"></span></p>
                </div>
                <span x-show="selectedCustomerId === c.id" class="text-blue-600">{{{icon "check-circle-2" class="w-5 h-5"}}}</span>
              </div>
            </button>
          </template>
        </div>
      </div>

      {{!-- Auto-fetched + contact info --}}
      <div x-show="selectedCustomerId" x-cloak class="pt-5 border-t border-gray-200">
        <p class="text-sm font-semibold text-gray-700 mb-3">{{labels.autoFetchedInfo}}</p>
        <div class="grid grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg">
          <div>
            <label class="text-xs text-gray-500">{{labels.customerName}}</label>
            <input x-model="customerName" disabled
              class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200" />
          </div>
          <div>
            <label class="text-xs text-gray-500">{{labels.gln}}</label>
            <input x-model="gln" disabled
              class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 font-mono" />
          </div>
        </div>

        <div class="mt-5">
          <p class="text-sm font-semibold text-gray-700 mb-3">{{labels.contactInfo}}</p>
          <div class="space-y-4">
            <div>
              <label class="text-xs text-gray-500">{{labels.contactPerson}} *</label>
              <input x-model="contactPerson" placeholder="{{labels.contactPersonPlaceholder}}"
                class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="text-xs text-gray-500">{{labels.phone}} *</label>
                <input x-model="phone" placeholder="{{labels.phonePlaceholder}}"
                  class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
              </div>
              <div>
                <label class="text-xs text-gray-500">{{labels.email}} *</label>
                <input x-model="email" type="email" placeholder="{{labels.emailPlaceholder}}"
                  class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
              </div>
            </div>
          </div>
        </div>
      </div>

      <div x-show="selectedCustomerId" x-cloak class="flex items-center gap-3 mt-6 pt-6 border-t border-gray-200">
        <button type="button" @click="submit()"
          :disabled="!contactPerson || !phone || !email"
          class="inline-flex items-center justify-center h-9 px-4 text-sm rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium disabled:opacity-50 disabled:pointer-events-none">
          {{labels.saveCustomer}}
        </button>
        <a href="/customers" class="inline-flex items-center justify-center h-9 px-4 text-sm rounded-lg bg-white border border-gray-200 text-gray-900 hover:bg-gray-50">{{labels.cancel}}</a>
      </div>
    </div>

    {{!-- MODE 2: Upload --}}
    <div x-show="mode === 'upload'" x-cloak class="p-6 bg-white shadow-sm border border-gray-100 rounded-xl space-y-5">

      <div class="flex items-center justify-between p-4 bg-blue-50 border border-blue-200 rounded-lg">
        <div>
          <p class="text-sm font-semibold text-blue-900">{{labels.downloadTemplate}}</p>
          <p class="text-xs text-blue-700 mt-1">Excel template to prepare your customer data.</p>
        </div>
        <button type="button" @click="downloadTemplate()"
          class="inline-flex items-center justify-center h-8 px-3 text-sm rounded-lg bg-white border border-blue-300 text-blue-700 hover:bg-blue-100">
          {{{icon "download" class="w-4 h-4 mr-2"}}}
          {{labels.downloadTemplate}}
        </button>
      </div>

      <div
        @dragover.prevent="isDragging = true"
        @dragleave.prevent="isDragging = false"
        @drop.prevent="handleDrop($event)"
        :class="isDragging ? 'border-blue-600 bg-blue-50' : 'border-gray-300 bg-gray-50 hover:border-gray-400'"
        class="border-2 border-dashed rounded-lg p-12 text-center transition-colors">
        <div class="text-gray-400 mx-auto mb-4 inline-block">{{{icon "upload" class="w-12 h-12"}}}</div>
        <p class="text-sm font-medium text-gray-900 mb-1">{{labels.uploadArea}}</p>
        <p class="text-xs text-gray-500 mb-4">{{labels.uploadAreaOr}}</p>
        <input x-ref="fileInput" type="file" accept=".xlsx,.csv" @change="handleFileSelect($event)" class="hidden" />
        <button type="button" @click="$refs.fileInput.click()"
          class="inline-flex items-center justify-center h-8 px-3 text-sm rounded-lg bg-white border border-gray-200 text-gray-900 hover:bg-gray-50">
          {{labels.uploadButton}}
        </button>
      </div>

      <div x-show="uploadResult" x-cloak class="p-5 bg-gray-50 rounded-lg border border-gray-200">
        <p class="text-sm font-semibold text-gray-900 mb-4">{{labels.uploadResult}}</p>
        <div class="grid grid-cols-2 gap-4">
          <div class="flex items-center gap-3 p-4 bg-green-50 border border-green-200 rounded-lg">
            <span class="text-green-600">{{{icon "check-circle-2" class="w-6 h-6"}}}</span>
            <div>
              <p class="text-2xl font-bold text-green-900" x-text="uploadResult?.successCount"></p>
              <p class="text-xs text-green-700">{{labels.successCount}}</p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-lg">
            <span class="text-red-600">{{{icon "x-circle" class="w-6 h-6"}}}</span>
            <div>
              <p class="text-2xl font-bold text-red-900" x-text="uploadResult?.errorCount"></p>
              <p class="text-xs text-red-700">{{labels.errorCount}}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 mt-6 pt-6 border-t border-gray-200">
        <a href="/customers" class="inline-flex items-center justify-center h-9 px-4 text-sm rounded-lg bg-white border border-gray-200 text-gray-900 hover:bg-gray-50">{{labels.cancel}}</a>
      </div>
    </div>

    {{!-- MODE 3: Manual entry --}}
    <form x-show="mode === 'manual'" x-cloak method="POST" action="/customers/new"
      @submit.prevent="submit()" class="p-6 bg-white shadow-sm border border-gray-100 rounded-xl space-y-5">

      <div>
        <p class="text-sm font-semibold text-gray-700 mb-3">{{labels.basicInfo}}</p>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-gray-500">{{labels.customerName}} *</label>
              <input x-model="customerName" name="customerName" placeholder="{{labels.customerNamePlaceholder}}"
                class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
            </div>
            <div>
              <label class="text-xs text-gray-500">{{labels.customerCode}} *</label>
              <input x-model="customerCode" name="customerCode" placeholder="{{labels.customerCodePlaceholder}}"
                class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
            </div>
          </div>

          <div>
            <label class="text-xs text-gray-500">{{labels.customerShortName}} *</label>
            <input x-model="customerShortName" name="customerShortName" placeholder="{{labels.customerShortNamePlaceholder}}"
              class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
          </div>

          <div>
            <label class="text-xs text-gray-500">{{labels.address}} *</label>
            <input x-model="address" name="address" placeholder="{{labels.addressPlaceholder}}"
              class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-gray-500">{{labels.taxOffice}} *</label>
              <input x-model="taxOffice" name="taxOffice" placeholder="{{labels.taxOfficePlaceholder}}"
                class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
            </div>
            <div>
              <label class="text-xs text-gray-500">{{labels.taxNumber}} *</label>
              <input x-model="taxNumber" name="taxNumber" placeholder="{{labels.taxNumberPlaceholder}}"
                class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-gray-500">{{labels.masterGln}} *</label>
              <input x-model="masterGln" name="masterGln" maxlength="13" placeholder="{{labels.masterGlnPlaceholder}}"
                class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition font-mono" />
            </div>
            <div>
              <label class="text-xs text-gray-500">{{labels.shipToGln}} *</label>
              <input x-model="shipToGln" name="shipToGln" maxlength="13" placeholder="{{labels.shipToGlnPlaceholder}}"
                class="mt-1.5 w-full h-9 px-3 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition font-mono" />
            </div>
          </div>

          {{!-- GLN (validation field) --}}
          <div>
            <label class="text-xs text-gray-500">{{labels.gln}} *</label>
            <div class="relative mt-1.5">
              <input x-model="gln" @input="validateGln()" name="gln" maxlength="13" placeholder="{{labels.masterGlnPlaceholder}}"
                class="w-full h-9 px-3 pr-10 py-1 text-sm rounded-lg border bg-white border-gray-200 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition font-mono" />
              <span class="absolute right-3 top-1/2 -translate-y-1/2">
                <template x-if="glnValidation === 'valid'">
                  <span class="text-green-600">{{{icon "check-circle-2" class="w-5 h-5"}}}</span>
                </template>
                <template x-if="glnValidation === 'invalid'">
                  <span class="text-red-600">{{{icon "x-circle" class="w-5 h-5"}}}</span>
                </template>
                <template x-if="glnValidation === 'duplicate'">
                  <span class="text-yellow-600">{{{icon "alert-circle" class="w-5 h-5"}}}</span>
                </template>
              </span>
            </div>
            <p class="mt-1 text-xs"
              :class="{
                'text-green-600': glnValidation === 'valid',
                'text-red-600': glnValidation === 'invalid',
                'text-yellow-600': glnValidation === 'duplicate',
                'text-gray-500': glnValidation === 'idle'
              }"
              x-text="glnMessage()"></p>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 mt-6 pt-6 border-t border-gray-200">
        <button type="submit"
          :disabled="!manualReady()"
          class="inline-flex items-center justify-center h-9 px-4 text-sm rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium disabled:opacity-50 disabled:pointer-events-none">
          {{labels.saveCustomer}}
        </button>
        <a href="/customers" class="inline-flex items-center justify-center h-9 px-4 text-sm rounded-lg bg-white border border-gray-200 text-gray-900 hover:bg-gray-50">{{labels.cancel}}</a>
      </div>
    </form>

  </div>

  {{!-- Lightweight toast (replaces sonner's notifications) --}}
  <div x-show="toastVisible" x-cloak x-transition.opacity
    :class="{
      'bg-green-600': toastTone === 'success',
      'bg-red-600': toastTone === 'error',
      'bg-blue-600': toastTone === 'info'
    }"
    class="fixed bottom-6 right-6 z-50 max-w-sm px-4 py-3 rounded-lg text-white text-sm shadow-lg">
    <p x-text="toastMessage"></p>
  </div>

  {{!-- Duplicate-warning modal --}}
  <div x-show="showDuplicate" x-cloak x-transition.opacity
    class="fixed inset-0 z-40 bg-black/40 flex items-center justify-center p-4"
    @click.self="showDuplicate = false">
    <div class="w-full max-w-md bg-white rounded-xl shadow-xl border border-gray-100 p-6 space-y-4">
      <div class="flex items-start gap-3">
        <span class="text-yellow-600 mt-0.5">{{{icon "alert-circle" class="w-6 h-6"}}}</span>
        <div>
          <h3 class="text-base font-semibold text-gray-900">{{labels.duplicateTitle}}</h3>
          <p class="text-sm text-gray-600 mt-1">{{labels.duplicateBody}}</p>
        </div>
      </div>
      <div class="bg-gray-50 rounded-lg p-3 text-sm text-gray-700">
        <p><strong x-text="duplicateCustomer.customerName"></strong></p>
        <p class="font-mono text-xs text-gray-500 mt-1">GLN: <span x-text="duplicateCustomer.gln"></span></p>
        <p class="text-xs text-gray-500 mt-1" x-text="duplicateCustomer.contactPerson + ' · ' + duplicateCustomer.phone"></p>
      </div>
      <div class="flex items-center gap-2 justify-end pt-2">
        <button type="button" @click="showDuplicate = false"
          class="inline-flex items-center justify-center h-9 px-4 text-sm rounded-lg bg-white border border-gray-200 text-gray-900 hover:bg-gray-50">{{labels.cancel}}</button>
        <button type="button" @click="onUseExisting()"
          class="inline-flex items-center justify-center h-9 px-4 text-sm rounded-lg bg-white border border-gray-200 text-gray-900 hover:bg-gray-50">{{labels.useExisting}}</button>
        <button type="button" @click="onCreateAnyway()"
          class="inline-flex items-center justify-center h-9 px-4 text-sm rounded-lg bg-blue-600 hover:bg-blue-700 text-white">{{labels.createAnyway}}</button>
      </div>
    </div>
  </div>
</div>

<script>
  // Alpine component owning all state for /customers/new. Mirrors the React
  // CreateCustomer component's behaviour: three modes, GLN validation,
  // duplicate detection against a mock dataset, drag-and-drop uploader, and
  // toast notifications. Mock arrays are passed in from the route handler.
  function createCustomer({ mockResults, existing, labels }) {
    return {
      mode: 'fetch',

      // Form fields
      customerName: '',
      customerCode: '',
      customerShortName: '',
      address: '',
      taxOffice: '',
      taxNumber: '',
      masterGln: '',
      shipToGln: '',
      gln: '',
      contactPerson: '',
      phone: '',
      email: '',

      // Fetch mode
      searchQuery: '',
      isSearching: false,
      searchResults: [],
      selectedCustomerId: null,

      // Upload mode
      uploadResult: null,
      isDragging: false,

      // Manual validation
      glnValidation: 'idle', // idle | valid | invalid | duplicate

      // Duplicate warning modal
      showDuplicate: false,
      duplicateCustomer: { customerName: '', gln: '', contactPerson: '', phone: '' },

      // Toast
      toastVisible: false,
      toastMessage: '',
      toastTone: 'info', // info | success | error
      _toastTimer: null,

      setMode(next) {
        this.mode = next;
        // Reset everything else — same UX as the React component
        this.customerName = this.customerCode = this.customerShortName = '';
        this.address = this.taxOffice = this.taxNumber = '';
        this.masterGln = this.shipToGln = this.gln = '';
        this.contactPerson = this.phone = this.email = '';
        this.searchQuery = '';
        this.searchResults = [];
        this.selectedCustomerId = null;
        this.uploadResult = null;
        this.glnValidation = 'idle';
      },

      toast(message, tone) {
        this.toastMessage = message;
        this.toastTone = tone || 'info';
        this.toastVisible = true;
        clearTimeout(this._toastTimer);
        this._toastTimer = setTimeout(() => { this.toastVisible = false; }, 2800);
      },

      // --- Fetch mode ---
      runSearch() {
        this.isSearching = true;
        // Simulate an API call (same 1s delay the React component used)
        setTimeout(() => {
          this.searchResults = mockResults;
          this.isSearching = false;
        }, 800);
      },
      selectSearchResult(c) {
        this.selectedCustomerId = c.id;
        this.customerName = c.name;
        this.gln = c.gln;
        this.toast(labels.fetchSuccess, 'success');
      },

      // --- Upload mode ---
      downloadTemplate() {
        this.toast(labels.downloadTemplate + '…', 'info');
        // Real implementation would trigger a real file download here.
      },
      handleFileSelect(e) {
        const file = e.target.files && e.target.files[0];
        if (file) this._mockUpload(file);
      },
      handleDrop(e) {
        this.isDragging = false;
        const file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
        if (!file) return;
        if (!/\.(xlsx|csv)$/i.test(file.name)) {
          this.toast('Please upload an Excel (.xlsx) or CSV file', 'error');
          return;
        }
        this._mockUpload(file);
      },
      _mockUpload(file) {
        this.toast('Uploading ' + file.name + '…', 'info');
        setTimeout(() => {
          this.uploadResult = { successCount: 8, errorCount: 2 };
          this.toast(this.uploadResult.successCount + ' ' + labels.uploadSuccess, 'success');
          if (this.uploadResult.errorCount > 0) {
            setTimeout(() => {
              this.toast(this.uploadResult.errorCount + ' ' + labels.uploadError, 'error');
            }, 600);
          }
        }, 1200);
      },

      // --- Manual validation ---
      validateGln() {
        const v = this.gln || '';
        if (v.length === 0) { this.glnValidation = 'idle'; return; }
        if (v.length !== 13 || !/^\d+$/.test(v)) { this.glnValidation = 'invalid'; return; }
        const dup = existing.find((c) => c.gln === v);
        this.glnValidation = dup ? 'duplicate' : 'valid';
      },
      glnMessage() {
        switch (this.glnValidation) {
          case 'valid': return labels.glnValid;
          case 'invalid': return labels.glnInvalid;
          case 'duplicate': return labels.glnDuplicate;
          default: return labels.glnValidation;
        }
      },
      manualReady() {
        return !!(this.customerName && this.customerCode && this.customerShortName &&
          this.address && this.taxOffice && this.taxNumber &&
          this.masterGln && this.shipToGln);
      },

      // --- Submit ---
      submit() {
        if (this.mode === 'manual') {
          if (!this.manualReady()) { this.toast(labels.validationRequired, 'error'); return; }
          if (this.glnValidation && this.glnValidation !== 'valid' && this.glnValidation !== 'idle') {
            if (this.glnValidation === 'invalid') {
              this.toast(labels.glnValidation, 'error');
              return;
            }
          }
          const dup = existing.find((c) => c.gln === this.gln);
          if (dup) {
            this.duplicateCustomer = dup;
            this.showDuplicate = true;
            return;
          }
        }
        // For both fetch & manual we just flash a toast and bounce back —
        // POST /customers/new currently doesn't persist. Once it does, replace
        // this with a real form submit.
        this.toast(labels.customerCreated, 'success');
        setTimeout(() => { window.location.href = '/customers'; }, 600);
      },
      onUseExisting() {
        this.showDuplicate = false;
        window.location.href = '/customers';
      },
      onCreateAnyway() {
        this.showDuplicate = false;
        this.toast(labels.customerCreated, 'success');
        setTimeout(() => { window.location.href = '/customers'; }, 600);
      },
    };
  }
</script>
