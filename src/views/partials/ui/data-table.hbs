{{!--
  DataTable — mirrors src/components/ui/DataTable.tsx
  Inputs (set in the page or route handler):
    columns       array of {key, header, headerClass, className, render}
                  where `render` may be the name of a sub-partial, or a function
                  ahead of time the route already serialized into safe HTML.
    data          array of row objects
    rowsHtml      pre-rendered <tr>…</tr> markup for the body (used when columns'
                  rendering varies too much for a single template to express).
    emptyMessage  fallback for empty data

  Most pages will set `rowsHtml` in their controller and just pass columns +
  rowsHtml here. The partial accepts either rowsHtml OR data+columns with simple
  string fields — see the page templates for examples.
--}}
<div class="overflow-x-auto bg-white shadow-sm border border-gray-100 rounded-xl">
  <table class="w-full">
    <thead class="border-b border-gray-100 bg-gray-50/60">
      <tr>
        {{#each columns}}
          <th class="px-5 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide {{this.className}}">{{{this.header}}}</th>
        {{/each}}
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      {{#if rowsHtml}}
        {{{rowsHtml}}}
      {{else}}
        {{#if data.length}}
          {{#each data}}
            <tr class="hover:bg-gray-50/70 transition-colors">
              {{#each ../columns}}
                <td class="px-5 py-4 text-sm text-gray-700 {{this.className}}">{{lookup .. this.key}}</td>
              {{/each}}
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="{{columns.length}}" class="px-5 py-12 text-center text-sm text-gray-500">{{#if emptyMessage}}{{emptyMessage}}{{else}}No data available{{/if}}</td>
          </tr>
        {{/if}}
      {{/if}}
    </tbody>
  </table>
</div>
