{{!--
  Badge partial — mirrors src/components/ui/Badge.tsx
  Usage:
    {{> ui/badge label="Completed" tone="green" variant="outline"}}

  Params:
    label    string text (or use block form for richer content)
    tone     green | orange | blue | red | gray
    variant  plain | outline (default plain)
--}}
<span class="inline-flex rounded-full px-2 py-1 text-xs font-medium
  {{#if (eq variant "outline")}}
    {{#if (eq tone "green")}}bg-transparent text-green-700 border border-green-200{{/if}}
    {{#if (eq tone "orange")}}bg-transparent text-orange-700 border border-orange-200{{/if}}
    {{#if (eq tone "blue")}}bg-transparent text-blue-700 border border-blue-200{{/if}}
    {{#if (eq tone "red")}}bg-transparent text-red-700 border border-red-200{{/if}}
    {{#if (or (eq tone "gray") (not tone))}}bg-transparent text-gray-700 border border-gray-200{{/if}}
  {{else}}
    {{#if (eq tone "green")}}bg-green-100 text-green-700{{/if}}
    {{#if (eq tone "orange")}}bg-orange-100 text-orange-700{{/if}}
    {{#if (eq tone "blue")}}bg-blue-100 text-blue-700{{/if}}
    {{#if (eq tone "red")}}bg-red-100 text-red-700{{/if}}
    {{#if (or (eq tone "gray") (not tone))}}bg-gray-100 text-gray-700{{/if}}
  {{/if}}
  {{extraClass}}">{{#if label}}{{label}}{{else}}{{> @partial-block}}{{/if}}</span>
