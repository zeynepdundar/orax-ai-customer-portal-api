{{!--
  Search input — mirrors src/components/ui/SearchInput.tsx
  Renders a label + input with a search icon on the left.
  Params: name, label, placeholder, value, xModel
--}}
<div>
  {{#if label}}<label class="block text-xs font-medium text-gray-700 mb-2">{{label}}</label>{{/if}}
  <div class="relative">
    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">{{{icon "search" class="w-4 h-4"}}}</span>
    <input
      {{#if name}}name="{{name}}" id="{{name}}"{{/if}}
      type="search"
      placeholder="{{placeholder}}"
      {{#if value}}value="{{value}}"{{/if}}
      {{#if xModel}}x-model="{{xModel}}"{{/if}}
      class="w-full h-9 pl-10 pr-3 py-1 text-sm rounded-lg border bg-white border-gray-200 placeholder:text-gray-400 focus-visible:ring-2 focus-visible:ring-brand-500/20 focus-visible:border-brand-500 outline-none transition"
    />
  </div>
</div>
