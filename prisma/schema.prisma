// Prisma schema for the Orax Customer Portal.
//
// The `portal.tenants` table lives in a non-default Postgres schema, so we
// enable `multiSchema` and explicitly list the schemas Prisma should manage.
//
// The Tenant model below is a *minimal placeholder* — id + a few common columns —
// just enough for the type generator to succeed before you've introspected the
// real database. Once your DB is reachable, run:
//
//     npx prisma db pull
//
// to overwrite this file with the exact column types from `portal.tenants` (and
// any other `portal.*` tables you want to expose).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["portal"]
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt        @map("updated_at")

  @@map("tenants")
  @@schema("portal")
}
